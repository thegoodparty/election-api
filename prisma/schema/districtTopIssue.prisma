model DistrictTopIssue {
  id        String   @id @map("id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  district   District @relation(fields: [districtId], references: [id])
  districtId String   @map("district_id") @db.Uuid

  // Denormalized from the dbt mart so callers can query without joining District.
  L2State        String @map("l2_state") @db.Char(2)
  L2DistrictType String @map("l2_district_type")
  L2DistrictName String @map("l2_district_name")

  // Number of L2 voters used to compute the average issue scores for this district
  L2VoterCount Int @map("l2_voter_count")

  // Haystaq issue score column name (e.g. hs_charter_schools_support)
  issue      String
  issueLabel String @map("issue_label")
  // Average Haystaq score across voters in the district (0-100)
  score      Float
  // Rank of the issue within the district (1 = highest score)
  issueRank  Int @map("issue_rank")

  @@unique([districtId, issue])
}
